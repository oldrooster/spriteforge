## Google AI Studio (simple API key setup)
GEMINI_API_KEY=your-api-key-here

# Google Cloud Vertex AI (optional — set GOOGLE_CLOUD_PROJECT to use instead of GEMINI_API_KEY)
# Vertex AI gives access to Veo 3.x video models and Gemini 3.x image models
# Requires vertex-secret.json service account key in the project root
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
#GOOGLE_CLOUD_VIDEO_LOCATION=